NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
# Use comma-separated public origins when frontend and API are hosted separately.
# APP_URL=https://kevindydyghg-bit.github.io,https://sati-timsa.onrender.com

DATABASE_URL=postgres://postgres:postgres@localhost:5432/sati_timsa
# Vercel + Supabase: use the Supabase Pooler connection string and PGSSLMODE=require.
PGSSLMODE=disable
# For Vercel serverless + Supabase, use PG_POOL_MAX=1.
PG_POOL_MAX=12
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=8000
PG_STATEMENT_TIMEOUT_MS=15000
PG_QUERY_TIMEOUT_MS=20000

# Generate a JWT_SECRET with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_very_long_random_secret_with_at_least_32_chars
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12

ADMIN_NAME=Administrador TI
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@sati-timsa.local
# ADMIN_PASSWORD is REQUIRED for admin creation. Use a strong password (min 8 chars).
ADMIN_PASSWORD=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=app-password-de-gmail
SMTP_FROM=tu-correo@gmail.com
SMTP_TEST_TO=

# If the frontend is hosted separately from the API, set this in
# frontend/assets/js/config.js to the public API origin, for example:
# window.SATI_API_BASE_URL = 'https://sati-timsa.onrender.com';

