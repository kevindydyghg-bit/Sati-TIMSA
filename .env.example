NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

DATABASE_URL=postgres://postgres:postgres@localhost:5432/sati_timsa
PGSSLMODE=disable
PG_POOL_MAX=12
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=8000
PG_STATEMENT_TIMEOUT_MS=15000
PG_QUERY_TIMEOUT_MS=20000

JWT_SECRET=change_this_to_a_very_long_random_secret
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12

ADMIN_NAME=Administrador TI
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@sati-timsa.local
ADMIN_PASSWORD=Admin123!

# Optional Gmail/SMTP for password reset codes.
# Use an app password, not the personal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Storage for equipment images.
# local = saves files in uploads/equipment for development.
# supabase = recommended for free cloud deploys because platform disks are often temporary.
STORAGE_DRIVER=local
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=equipment-images
